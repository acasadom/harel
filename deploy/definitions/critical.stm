event Finish {}
event Refunded {}
machine critical {
  initial Working

  state Working { on enter demo_actions.rec(at: "working") }
  state Releasing { on enter demo_actions.rec(at: "releasing") }
  final Cancelled cancelled { on enter demo_actions.rec(at: "cancelled") }
  final Done success { on enter demo_actions.rec(at: "done") }

  from Working to Done on Finish
  from Working to Releasing on Cancel
  from Releasing to Cancelled on Refunded
}
